{
  "name": "toonlivre-extrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "CLI extractor for ToonLivre client request and decryption manifests.",
  "bin": {
    "toonlivre-extrator": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "clean": "rm -rf dist coverage",
    "dev": "tsx src/cli.ts",
    "extract": "tsx src/cli.ts extract",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "test": "vitest run tests/unit",
    "test:unit": "vitest run tests/unit",
    "test:live": "RUN_LIVE_TESTS=1 vitest run tests/live",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@babel/parser": "^7.28.0",
    "@babel/traverse": "^7.28.0",
    "@babel/types": "^7.28.0",
    "cheerio": "^1.1.2",
    "commander": "^14.0.0",
    "crypto-js": "^4.2.0",
    "zod": "^4.1.5"
  },
  "devDependencies": {
    "@eslint/js": "^9.35.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^24.3.0",
    "eslint": "^9.35.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^16.4.0",
    "prettier": "^3.6.2",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.42.0",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  }
}
